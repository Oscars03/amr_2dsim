<?xml version="1.0"?>
<robot name="amr_robot">

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.1" rpy="0 0 0"/>
      <geometry>
        <box size="0.6 0.4 0.2"/> 
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.3 0.8 1"/>
      </material>
    </visual>
  </link>

  <link name="laser_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.05"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="0.2 0 0.25" rpy="0 0 0"/> </joint>

  <!-- ============================================================ -->
  <!--  AMR 2D SIMULATOR CONFIG — reference template for new URDFs  -->
  <!--    wheel_base   = distance between left/right drive wheels   -->
  <!--    robot_radius = collision radius (half-diagonal or custom)  -->
  <!-- ============================================================ -->
  <amr_sim_config>
    <kinematic_model>diff_drive</kinematic_model>
    <wheel_base>0.5</wheel_base>
    <robot_radius>0.35</robot_radius>
    <laser_range_max>12.0</laser_range_max>
    <ticks_per_meter>1000.0</ticks_per_meter>
  </amr_sim_config>

</robot>