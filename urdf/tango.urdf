<?xml version="1.0"?>
<robot name="tango_robot">

  <!--
  ================================================================
  TANGO ROBOT SPECIFICATIONS:
  - Body: 30x30 cm square (0.3 x 0.3 m)
  - Corner Fillets: 3 cm radius (0.03 m)
  - Height: 10 cm (0.1 m)
  - LiDAR: Front center, half way (x=-0.025 from base_link)
  - Drive System: DIFFERENTIAL DRIVE
      • Front Left  (FL) : DRIVE wheel (continuous joint)
      • Front Right (FR) : DRIVE wheel (continuous joint)
      • Rear Left   (RL) : FREE / Caster wheel (continuous passive)
      • Rear Right  (RR) : FREE / Caster wheel (continuous passive)

  X-AXIS ORIGIN CONVENTION (ROS diff_drive standard):
    base_link origin = DRIVE AXLE center (kinematic pivot point / ICC)
    All X offsets are measured from the drive axle:
      Drive wheels (FL/FR)  x =  0.000  (at drive axle)
      Body geometric center x = -0.100  (100 mm behind drive axle)
      LiDAR                 x = -0.025  (75 mm ahead of body center → 25 mm behind axle)
      Caster wheels (RL/RR) x = -0.200  (200 mm behind drive axle)

  Z-AXIS ORIGIN CONVENTION (base_link = ground plane):
    - Wheel radius   = 0.040 m  → wheel centers at z = 0.040
    - Body bottom    = z = 0.040 (rests on top of wheel plane)
    - Body center    = z = 0.040 + 0.050 = 0.090
    - Body top       = z = 0.040 + 0.100 = 0.140
    - LiDAR center   = z = 0.140 + 0.025 = 0.165
  ================================================================

  DRIVE LAYOUT (top view, relative to base_link = drive axle):
         FRONT (+X) →
       ___________
  [FL]/           \[FR]   ← DRIVE WHEELS at x=0.000 (drive axle = base_link)
     |   TANGO    |
  [RL]\___________/[RR]   ← FREE WHEELS  at x=-0.200 (casters)

  Differential drive control:
    - Turn LEFT  : FL slower than FR
    - Turn RIGHT : FR slower than FL
    - Go FORWARD : FL = FR same speed forward
    - Go BACK    : FL = FR same speed reverse
    - SPIN       : FL and FR opposite directions
  ================================================================
  -->

  <!-- ============================================================ -->
  <!--                     MATERIALS                                -->
  <!-- ============================================================ -->

  <material name="tango_body">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>

  <material name="lidar_body">
    <color rgba="0.2 0.2 0.2 1.0"/>
  </material>

  <material name="lidar_window">
    <color rgba="0.8 0.1 0.1 1.0"/>
  </material>

  <material name="lidar_mount">
    <color rgba="0.4 0.4 0.4 1.0"/>
  </material>

  <material name="drive_wheel">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>

  <material name="free_wheel">
    <color rgba="0.45 0.45 0.45 1.0"/>
  </material>

  <material name="wheel_hub">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>

  <!-- ============================================================ -->
  <!--                   BASE FOOTPRINT LINK                        -->
  <!--  RViz / nav2 convention: ground-level origin link            -->
  <!-- ============================================================ -->

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!--
      base_link origin is at the drive axle, ground level (z=0).
      base_footprint is co-located (both at drive axle ground point).
    -->
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================ -->
  <!--                        BASE LINK                             -->
  <!--  Origin = drive axle center at ground level                  -->
  <!--  (ROS diff_drive convention: ICC = base_link origin)         -->
  <!-- ============================================================ -->

  <link name="base_link">

    <!-- === MAIN BODY BOX ===
         Body geometric center is 100 mm BEHIND drive axle (x = -0.100)
         Bottom of body = wheel radius = 0.040 m above ground
         Body center z  = 0.040 + 0.050 = 0.090 m
    -->
    <visual>
      <origin xyz="-0.100 0 0.090" rpy="0 0 0"/>
      <geometry>
        <box size="0.300 0.300 0.100"/>
      </geometry>
      <material name="tango_body"/>
    </visual>

    <!--
      FILLET CORNER CYLINDERS:
      Corners at (body_center_x ± 0.120, ±0.120) = (-0.100 ± 0.120, ±0.120)
        Front corners: x = -0.100 + 0.120 = +0.020
        Rear  corners: x = -0.100 - 0.120 = -0.220
      Radius = 0.030 m matches 3 cm fillet spec.
    -->

    <!-- Corner: FRONT LEFT (+X side, +Y) -->
    <visual>
      <origin xyz="0.020 0.120 0.090" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.030" length="0.100"/>
      </geometry>
      <material name="tango_body"/>
    </visual>

    <!-- Corner: FRONT RIGHT (+X side, -Y) -->
    <visual>
      <origin xyz="0.020 -0.120 0.090" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.030" length="0.100"/>
      </geometry>
      <material name="tango_body"/>
    </visual>

    <!-- Corner: REAR LEFT (-X side, +Y) -->
    <visual>
      <origin xyz="-0.220 0.120 0.090" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.030" length="0.100"/>
      </geometry>
      <material name="tango_body"/>
    </visual>

    <!-- Corner: REAR RIGHT (-X side, -Y) -->
    <visual>
      <origin xyz="-0.220 -0.120 0.090" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.030" length="0.100"/>
      </geometry>
      <material name="tango_body"/>
    </visual>

    <!--
      NOTE ON CORNER MASKING IN RViz:
      RViz does not support alpha=0 transparency. The original "corner_mask"
      approach used invisible boxes which rendered as BLACK in RViz.
      FIX: The fillet cylinders overlap the box corners naturally.
           The body box size is REDUCED on X and Y to 0.240 m so the box
           edges sit inside the cylinder radius, giving a clean fillet look
           without any masking needed.
           Two cross-bars complete the rectangular silhouette.
    -->

    <!-- X-axis cross bar (full length, narrow Y) -->
    <visual>
      <origin xyz="-0.100 0 0.090" rpy="0 0 0"/>
      <geometry>
        <box size="0.300 0.240 0.100"/>
      </geometry>
      <material name="tango_body"/>
    </visual>

    <!-- Y-axis cross bar (full width, narrow X) -->
    <visual>
      <origin xyz="-0.100 0 0.090" rpy="0 0 0"/>
      <geometry>
        <box size="0.240 0.300 0.100"/>
      </geometry>
      <material name="tango_body"/>
    </visual>

    <!-- === COLLISION (simple bounding box) === -->
    <collision>
      <origin xyz="-0.100 0 0.090" rpy="0 0 0"/>
      <geometry>
        <box size="0.300 0.300 0.100"/>
      </geometry>
    </collision>

    <!-- === INERTIAL ===
      Mass: 8.0 kg  |  Body size: 0.30 x 0.30 x 0.10 m
      Ixx = (1/12)*8*(0.30²+0.10²) = (1/12)*8*0.1000 = 0.06667
      Iyy = (1/12)*8*(0.30²+0.10²) = (1/12)*8*0.1000 = 0.06667
      Izz = (1/12)*8*(0.30²+0.30²) = (1/12)*8*0.1800 = 0.12000
      CoM at body center = x=-0.100, z=0.090
    -->
    <inertial>
      <origin xyz="-0.100 0 0.090" rpy="0 0 0"/>
      <mass value="8.0"/>
      <inertia
        ixx="0.06667" ixy="0.0" ixz="0.0"
        iyy="0.06667" iyz="0.0"
        izz="0.12000"/>
    </inertial>

  </link>

  <!-- ============================================================ -->
  <!--                      LIDAR LINK                              -->
  <!-- ============================================================ -->

  <link name="laser_link">

    <!-- Main LiDAR Housing -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.040" length="0.050"/>
      </geometry>
      <material name="lidar_body"/>
    </visual>

    <!-- Scanning Window (top red ring) -->
    <visual>
      <origin xyz="0 0 0.020" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.038" length="0.010"/>
      </geometry>
      <material name="lidar_window"/>
    </visual>

    <!-- Mounting Base Plate -->
    <visual>
      <origin xyz="0 0 -0.030" rpy="0 0 0"/>
      <geometry>
        <box size="0.090 0.090 0.010"/>
      </geometry>
      <material name="lidar_mount"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.040" length="0.050"/>
      </geometry>
    </collision>

    <!--
      Inertia for small cylinder: mass=0.2 kg, r=0.04m, h=0.05m
      Ixx = Iyy = (1/12)*0.2*(3*0.04²+0.05²) = (1/12)*0.2*(0.0048+0.0025) = 0.0001217
      Izz        = (1/2)*0.2*0.04²            = 0.5*0.2*0.0016             = 0.0001600
    -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia
        ixx="0.0001217" ixy="0.0" ixz="0.0"
        iyy="0.0001217" iyz="0.0"
        izz="0.0001600"/>
    </inertial>

  </link>

  <!-- LiDAR Joint
    base_link origin = drive axle at ground.
    Body front edge  = drive_axle + 0.150 = +0.150 from base_link
    LiDAR at body front midpoint: body_center_x + 0.075 = -0.100 + 0.075 = -0.025
    z: body top (0.140) + half lidar height (0.025) = 0.165 m
    y = 0.000 (centered)
  -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="-0.025 0.000 0.165" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================ -->
  <!--          FRONT LEFT WHEEL  — DRIVE WHEEL                     -->
  <!-- ============================================================ -->
  <!--
    ★ DRIVE WHEEL — motor actuated (diff_drive_controller)
    x = 0.000  (AT drive axle = base_link origin)
    y = +0.1625 m  (body half-width 0.150 + wheel half-width 0.0125)
    z = 0.040 m (wheel radius)
  -->

  <link name="wheel_front_left_link">

    <!-- Tire -->
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.040" length="0.025"/>
      </geometry>
      <material name="drive_wheel"/>
    </visual>

    <!-- Hub cap (outboard face: +Y side) -->
    <visual>
      <origin xyz="0 0.0145 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.004"/>
      </geometry>
      <material name="wheel_hub"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.040" length="0.025"/>
      </geometry>
    </collision>

    <!--
      Wheel inertia: mass=0.35 kg, r=0.04 m, h=0.025 m
      Ixx=Izz = (1/12)*0.35*(3*0.04²+0.025²) = (1/12)*0.35*0.005425 = 0.0001582
      Iyy (spin axis) = (1/2)*0.35*0.04²      = 0.000280
    -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.35"/>
      <inertia
        ixx="0.0001582" ixy="0.0" ixz="0.0"
        iyy="0.0002800" iyz="0.0"
        izz="0.0001582"/>
    </inertial>

  </link>

  <joint name="wheel_front_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_left_link"/>
    <origin xyz="0.000 0.1625 0.040" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.1"/>
  </joint>

  <!-- ============================================================ -->
  <!--          FRONT RIGHT WHEEL — DRIVE WHEEL                     -->
  <!-- ============================================================ -->

  <link name="wheel_front_right_link">

    <!-- Tire -->
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.040" length="0.025"/>
      </geometry>
      <material name="drive_wheel"/>
    </visual>

    <!-- Hub cap (outboard face: -Y side) -->
    <visual>
      <origin xyz="0 -0.0145 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.018" length="0.004"/>
      </geometry>
      <material name="wheel_hub"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.040" length="0.025"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.35"/>
      <inertia
        ixx="0.0001582" ixy="0.0" ixz="0.0"
        iyy="0.0002800" iyz="0.0"
        izz="0.0001582"/>
    </inertial>

  </link>

  <joint name="wheel_front_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_front_right_link"/>
    <origin xyz="0.000 -0.1625 0.040" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.1"/>
  </joint>

  <!-- ============================================================ -->
  <!--          REAR LEFT WHEEL  — FREE / CASTER WHEEL              -->
  <!-- ============================================================ -->
  <!--
    ○ FREE WHEEL — passive, no motor
    Slightly narrower (length=0.020) to visually distinguish from drive wheels
  -->

  <link name="wheel_rear_left_link">

    <!-- Tire -->
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.040" length="0.020"/>
      </geometry>
      <material name="free_wheel"/>
    </visual>

    <!-- Caster housing ring (outboard face: +Y side) -->
    <visual>
      <origin xyz="0 0.013 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.006"/>
      </geometry>
      <material name="wheel_hub"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.040" length="0.020"/>
      </geometry>
    </collision>

    <!--
      Free wheel inertia: mass=0.20 kg, r=0.04 m, h=0.020 m
      Ixx=Izz = (1/12)*0.20*(3*0.04²+0.02²) = (1/12)*0.20*0.005200 = 0.0000867
      Iyy      = (1/2)*0.20*0.04²            = 0.0001600
    -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.20"/>
      <inertia
        ixx="0.0000867" ixy="0.0" ixz="0.0"
        iyy="0.0001600" iyz="0.0"
        izz="0.0000867"/>
    </inertial>

  </link>

  <joint name="wheel_rear_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rear_left_link"/>
    <origin xyz="-0.200 0.1625 0.040" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.001" friction="0.01"/>
  </joint>

  <!-- ============================================================ -->
  <!--          REAR RIGHT WHEEL — FREE / CASTER WHEEL              -->
  <!-- ============================================================ -->

  <link name="wheel_rear_right_link">

    <!-- Tire -->
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.040" length="0.020"/>
      </geometry>
      <material name="free_wheel"/>
    </visual>

    <!-- Caster housing ring (outboard face: -Y side) -->
    <visual>
      <origin xyz="0 -0.013 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.022" length="0.006"/>
      </geometry>
      <material name="wheel_hub"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.040" length="0.020"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.20"/>
      <inertia
        ixx="0.0000867" ixy="0.0" ixz="0.0"
        iyy="0.0001600" iyz="0.0"
        izz="0.0000867"/>
    </inertial>

  </link>

  <joint name="wheel_rear_right_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_rear_right_link"/>
    <origin xyz="-0.200 -0.1625 0.040" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.001" friction="0.01"/>
  </joint>

  <!-- ============================================================ -->
  <!--              ROS2 CONTROL INTERFACE                          -->
  <!--  Required for RViz to publish /joint_states correctly        -->
  <!-- ============================================================ -->

  <ros2_control name="tango_diff_drive" type="system">
    <hardware>
      <!-- Swap for real hardware plugin when deploying on robot -->
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>

    <!-- DRIVE WHEEL — Front Left -->
    <joint name="wheel_front_left_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- DRIVE WHEEL — Front Right -->
    <joint name="wheel_front_right_joint">
      <command_interface name="velocity">
        <param name="min">-10</param>
        <param name="max">10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- FREE WHEEL — Rear Left (state only, no command) -->
    <joint name="wheel_rear_left_joint">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- FREE WHEEL — Rear Right (state only, no command) -->
    <joint name="wheel_rear_right_joint">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

  </ros2_control>

  <!-- ============================================================ -->
  <!--              GAZEBO DIFF DRIVE PLUGIN CONFIG                 -->
  <!-- ============================================================ -->
  <!--
    WHEEL SEPARATION = 0.325 m  (y: 0.1625 × 2, left-to-right center)
    WHEEL DIAMETER   = 0.080 m  (radius 0.040 × 2)
  -->

  <gazebo>
    <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <namespace>/tango</namespace>
      </ros>
      <left_joint>wheel_front_left_joint</left_joint>
      <right_joint>wheel_front_right_joint</right_joint>
      <wheel_separation>0.325</wheel_separation>
      <wheel_diameter>0.080</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>1.0</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>true</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_link</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- ============================================================ -->
  <!--        AMR 2D SIMULATOR CONFIG                               -->
  <!--  Values derived from geometry defined above:                 -->
  <!--    wheel_base   = y-offset of drive wheels × 2              -->
  <!--                   = 0.1625 × 2 = 0.325 m                    -->
  <!--    robot_radius = distance from drive axle to farthest point -->
  <!--                   = rear edge (0.200) + half-width (0.150)  -->
  <!--                   → worst case = sqrt(0.200²+0.150²) ≈ 0.250 -->
  <!--    drive_axle_x = x of drive wheels in base_link frame       -->
  <!--                   = 0.000 (at base_link origin per convention)-->
  <!-- ============================================================ -->
  <amr_sim_config>
    <kinematic_model>diff_drive</kinematic_model>
    <wheel_base>0.325</wheel_base>
    <robot_radius>0.250</robot_radius>
    <laser_range_max>12.0</laser_range_max>
    <ticks_per_meter>1000.0</ticks_per_meter>
    <drive_axle_x>0.000</drive_axle_x>
  </amr_sim_config>

</robot>